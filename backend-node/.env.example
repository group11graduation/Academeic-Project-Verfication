# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/academic_verification

# JWT (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Python AI service (proposal/code similarity, etc.)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=120000

# Logging
LOG_LEVEL=info
