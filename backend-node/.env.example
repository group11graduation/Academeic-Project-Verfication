# =============================================================================
# Step 1 — core runtime (local development)
# Copy to `.env` and adjust for your machine / Docker volumes later.
# =============================================================================

# Server (code default PORT=3000 if unset)
NODE_ENV=development
PORT=5000

# MongoDB — prefer MONGO_URI; MONGODB_URI is still supported
MONGO_URI=mongodb://127.0.0.1:27017/academic_verification
# MONGODB_URI=mongodb://127.0.0.1:27017/academic_verification

# User uploads root (must match Docker volume mount in deployment)
# Relative paths resolve from backend-node/
UPLOAD_DIR=./uploads

# Python FastAPI AI service (code default: http://localhost:8000)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=120000

# JWT — MUST match project root `.env` JWT_SECRET when using Docker (docker compose reads root `.env`)
# Generate: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=info

# Docker multi-stack previews (PHP / Node / Jupyter)
DOCKER_PREVIEW_ENABLED=true
# Public URL base for teacher preview links (no trailing slash). On VPS set to your server IP or domain.
# Example: PREVIEW_PUBLIC_HOST=http://173.212.235.206
PREVIEW_PUBLIC_HOST=http://localhost
# When node-backend runs in Docker, preview ports bind on the host — probe via host.docker.internal
PREVIEW_PROBE_HOST=host.docker.internal
PREVIEW_PORT_MIN=8000
PREVIEW_PORT_MAX=9000
PREVIEW_BUILD_TIMEOUT_MS=600000
# One-time base image build for Flutter previews (SDK only, not the student ZIP)
PREVIEW_FLUTTER_BUILD_TIMEOUT_MS=900000
# Node / PHP / Jupyter previews bind-mount the ZIP — reusable base images (built once at startup)
# Persistent workspace + Maven/npm caches speed up 2nd+ preview start (same submission ZIP)
PREVIEW_WORKSPACE_CACHE=true
PREVIEW_DEPENDENCY_CACHE=true
# PREVIEW_CACHE_ROOT=./data/preview-cache
# PREVIEW_MAVEN_CACHE_DIR=
# PREVIEW_NPM_CACHE_DIR=
# PREVIEW_NODE_BASE_IMAGE=scholarverify-preview-node:latest
# PREVIEW_NODE_FLUTTER_BASE_IMAGE=scholarverify-preview-node-flutter:latest
# PREVIEW_PHP_BASE_IMAGE=scholarverify-preview-php:latest
# PREVIEW_JUPYTER_BASE_IMAGE=scholarverify-preview-jupyter:latest
# PREVIEW_SPRING_REACT_BASE_IMAGE=scholarverify-preview-java-spring-react:latest
# PREVIEW_WARM_BASE_IMAGES=true
# PREVIEW_FORCE_REBUILD_BASE=true
PREVIEW_STARTUP_TIMEOUT_MS=300000
# Poll host port mapping after docker run (Docker may take seconds to publish -p)
PREVIEW_PORT_PUBLISH_POLL_MS=500
PREVIEW_PORT_PUBLISH_GRACE_MS=20000
PREVIEW_STARTUP_POLL_MS=1000
# Shorter poll when teacher UI refreshes session status (avoid blocking API too long)
PREVIEW_SESSION_PORT_PROBE_MS=5000
PREVIEW_NODE_STARTUP_TIMEOUT_MS=600000
# How long a preview stays up after it is ready (default 30 min; extends while teacher page is open)
PREVIEW_TTL_MS=1800000
# ZIP extract limits (HTML/CSS sites with many images need higher file count)
PREVIEW_MAX_EXTRACT_FILES=3000
PREVIEW_MAX_EXTRACT_BYTES=104857600
# Sandbox resource limits (docker run --memory / --cpus)
PREVIEW_SANDBOX_MEMORY=256m
PREVIEW_SANDBOX_CPUS=0.5
# Max wait for `docker run` to return a container id (force rm -f on timeout)
PREVIEW_SPRING_STARTUP_TIMEOUT_MS=1800000
PREVIEW_SPRING_BUILD_TIMEOUT_MS=1800000
PREVIEW_JAVA_BASE_IMAGE=eclipse-temurin:17-jdk-jammy
PREVIEW_JAVA_PULL_TIMEOUT_MS=600000
PREVIEW_SPRING_SANDBOX_MEMORY=1536m
# Default teacher preview login (used when student ZIP has no .env hints)
PREVIEW_DEFAULT_ADMIN_EMAIL=admin@preview.demo
PREVIEW_DEFAULT_ADMIN_USERNAME=previewadmin
PREVIEW_DEFAULT_ADMIN_PASSWORD=Preview123!
PREVIEW_JWT_SECRET=preview-sandbox-jwt-secret
# MongoDB for student app inside preview (Docker Desktop → host MongoDB)
PREVIEW_MONGODB_URI=mongodb://host.docker.internal:27017/scholarverify_preview
# MERN preview uses a MongoDB sidecar container (set false to use host Mongo via PREVIEW_MONGODB_URI)
PREVIEW_SIDECAR_MONGO=true
PREVIEW_MONGO_IMAGE=mongo:7
PREVIEW_MONGO_PULL_TIMEOUT_MS=600000
PREVIEW_WARM_MONGO_IMAGE=true
# PHP preview uses a MariaDB sidecar (set false to use host MySQL via DB_HOST in project config)
PREVIEW_SIDECAR_MYSQL=true
PREVIEW_MYSQL_IMAGE=mariadb:11
PREVIEW_WARM_MYSQL_IMAGE=true
PREVIEW_MYSQL_DATABASE=bbms
