# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS: comma-separated origins, or * for dev
CORS_ORIGINS=*

# App
APP_NAME=Academic Verification AI Service

# Model cache (sentence-transformers, etc.)
MODELS_CACHE_DIR=/tmp/academic-ai-models

# Proposal similarity thresholds (cosine 0–1)
AI_SAME_SEMESTER_REJECT=0.72
AI_PREVIOUS_SEMESTER_WARN=0.58
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
# Set true for CI / lightweight env without downloading ST models
USE_TFIDF_FALLBACK=false

# Code similarity (optional endpoint)
CODE_SIMILARITY_WARN_THRESHOLD=0.85
CODEBERT_ENABLED=false
CODEBERT_MODEL=microsoft/codebert-base
