# =============================================================================
# Step 1 — core runtime (local development)
# Copy to `.env` and adjust for your machine / Docker volumes later.
# =============================================================================

# Server (code default PORT=8000 if unset)
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS: comma-separated origins, or * for dev
CORS_ORIGINS=*

# App
APP_NAME=Academic Verification AI Service

# Local SQLite + model cache (use DATA_DIR for Docker volume mapping)
DATA_DIR=./data
MODELS_CACHE_DIR=./data/models-cache
# EMBEDDING_CACHE_DB_PATH=
# ANALYSIS_JOBS_DB_PATH=

# Optional Redis for embedding hot cache
# REDIS_URL=

# Request body limit (bytes)
# MAX_REQUEST_BODY_BYTES=26214400

# Proposal similarity thresholds (cosine 0–1)
AI_SAME_SEMESTER_REJECT=0.72
AI_PREVIOUS_SEMESTER_WARN=0.58
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
# Set true for CI / lightweight env without downloading ST models
USE_TFIDF_FALLBACK=false

# Requirement meaning check (teacher requirements vs student proposal)
# Below REJECT → auto-reject (casual English / unrelated / keyword-only)
# Between REJECT and PASS → teacher review
# At/above PASS → clear for plagiarism AI
AI_REQUIREMENT_REJECT_BELOW=0.42
AI_REQUIREMENT_PASS_AT=0.58
AI_REQUIREMENT_MIN_PROPOSAL_CHARS=80
AI_REQUIREMENT_TECH_CONTEXT_PASS=0.48

# Code similarity (optional endpoint)
CODE_SIMILARITY_WARN_THRESHOLD=0.85
CODEBERT_ENABLED=false
CODEBERT_MODEL=microsoft/codebert-base
