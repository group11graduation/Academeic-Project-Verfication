# =============================================================================
# Project root — used by docker compose (copy to `.env` in this folder)
#
# Generate secrets (PowerShell):
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
#
# IMPORTANT: Use the SAME JWT_SECRET in backend-node/.env when running the API
# locally outside Docker. Mismatched secrets invalidate tokens after refresh.
# =============================================================================

# Required — persistent signing keys (min 32 chars; never use placeholders in production)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (UTC-based; container TZ is set to UTC in docker-compose.yml)
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend dev server origins (exact matches). Hosts here also allow any port on that host.
# Use * to allow all origins (preview / staging only).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public server deployment (docker compose / Coolify)
# Browser-visible backend URL — set to your API's public URL (no trailing slash).
# Example: https://api.yourdomain.com  or  http://YOUR_SERVER_IP:5000
PUBLIC_API_URL=

# Public URL used for live preview links (must be reachable from the browser).
# CORS allows this host on any port (e.g. http://YOUR_IP:8656).
PREVIEW_PUBLIC_HOST=http://localhost

# Frontend public URL for password-reset links and CORS (host allows any port).
FRONTEND_URL=http://localhost:5173
APP_NAME=Project Verify
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Project Verify <noreply@yourdomain.com>
AUTH_RETURN_RESET_TOKEN=false
