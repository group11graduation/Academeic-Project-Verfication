# =============================================================================
# Project root — used by docker compose (copy to `.env` in this folder)
#
# Generate secrets (PowerShell):
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
#
# IMPORTANT: Use the SAME JWT_SECRET in backend-node/.env when running the API
# locally outside Docker. Mismatched secrets invalidate tokens after refresh.
# =============================================================================

# Required — persistent signing keys (min 32 chars; never use placeholders in production)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (UTC-based; container TZ is set to UTC in docker-compose.yml)
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend dev server origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional overrides
# AI_SERVICE_TIMEOUT_MS=120000
# LOG_LEVEL=info
# DOCKER_PREVIEW_ENABLED=true
